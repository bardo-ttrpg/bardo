{
	"ignoreDependencies": ["turbo", "husky"],
	"workspaces": {
		".": {
			"entry": ["scripts/**/*.{js,cjs,mjs,ts}"],
			"project": ["scripts/**/*.{js,cjs,mjs,ts}"]
		},
		"website": {
			"entry": [
				"*.{test,spec}.{js,jsx,ts,tsx}",
				"app/**/*.{test,spec}.{js,jsx,ts,tsx}",
				"lib/**/*.{test,spec}.{js,jsx,ts,tsx}",
				"scripts/**/*.ts",
				"instrumentation-client.test.ts"
			],
			"project": ["**/*.{js,jsx,ts,tsx,mdx}"]
		},
		"packages/bardo-engine": {
			"entry": ["src/**/*.{test,spec}.{js,jsx,ts,tsx}"],
			"project": ["**/*.{js,jsx,ts,tsx}"]
		},
		"packages/bardo-shared": {
			"entry": ["src/**/*.{test,spec}.{js,jsx,ts,tsx}"],
			"project": ["**/*.{js,jsx,ts,tsx}"]
		},
		"packages/bardo-mcp": {
			"entry": ["scripts/**/*.ts", "src/**/*.{test,spec}.{js,jsx,ts,tsx}"],
			"project": ["**/*.{js,jsx,ts,tsx}"]
		}
	}
}
