{
	"extends": "../tsconfig.base.json",
	"compilerOptions": {
		"plugins": [
			{
				"name": "next"
			}
		],
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"incremental": true,
		"types": ["node"],
		"paths": {
			"@/*": ["./*"]
		}
	},
	"include": [
		"next-env.d.ts",
		"**/*.ts",
		"**/*.tsx",
		"**/*.d.ts",
		".next/types/**/*.ts"
	],
	"exclude": ["node_modules"]
}
