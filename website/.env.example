NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_JWT_ISSUER_DOMAIN=https://REPLACE_ME.clerk.accounts.dev

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Local Convex values are written by `bunx convex dev`.
NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210
CONVEX_DEPLOYMENT=anonymous:anonymous-docs
NEXT_PUBLIC_CONVEX_SITE_URL=http://127.0.0.1:3211
# Keep Convex temp files on the same filesystem as the repo to avoid cross-fs warnings.
CONVEX_TMPDIR=./convex/.tmp

CLERK_WEBHOOK_SECRET=whsec_REPLACE_ME

# Clerk Billing (Stripe-backed in Clerk dashboard)
NEXT_PUBLIC_APP_URL=http://localhost:3001
CLERK_BILLING_PLAN_SOLO=cplan_REPLACE_ME
CLERK_BILLING_PLAN_SOLO_PLUS=cplan_REPLACE_ME
CLERK_BILLING_PLAN_PARTY=cplan_REPLACE_ME

# Playwright + Clerk testing
PLAYWRIGHT_BASE_URL=http://localhost:3001
E2E_CLERK_USER_IDENTIFIER=
E2E_CLERK_USER_PASSWORD=
