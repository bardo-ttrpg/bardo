# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# BARDO_UPSTASH_TIMEOUT_MS=1200
# BARDO_MCP_USAGE_READ_TOTALS=false
# BARDO_MCP_USAGE_READ_KEY_METADATA=false
# BARDO_MCP_PERIOD_LIMIT_FREE=100
# BARDO_MCP_PERIOD_LIMIT_SOLO=25000
# BARDO_MCP_PERIOD_LIMIT_SOLO_PLUS=50000
