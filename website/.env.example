# Website environment template
# Use one section at a time. Do not mix local-dev, staging, and production values.

################################################################################
# local-dev
################################################################################

# Clerk auth (development instance)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Clerk billing plans
CLERK_BILLING_PLAN_SOLO=cplan_REPLACE_ME
CLERK_BILLING_PLAN_SOLO_PLUS=cplan_REPLACE_ME

# Website + MCP URLs
NEXT_PUBLIC_APP_URL=http://localhost:3001
BARDO_MCP_BASE_URL=http://127.0.0.1:3000

# Shared introspection secret (must match mcp/.env)
BARDO_AUTH_INTROSPECTION_TOKEN=replace_with_shared_server_secret

# Optional local cache for billing-plan lookup during key introspection
# BARDO_INTROSPECTION_PLAN_CACHE_TTL_MS=300000
# BARDO_INTROSPECTION_VERIFY_CACHE_TTL_MS=120000
# BARDO_INTROSPECTION_INVALID_CACHE_TTL_MS=20000
# BARDO_INTROSPECTION_TELEMETRY_LOG=false
# BARDO_INTROSPECTION_TELEMETRY_LOG_EVERY=100

# Keep default simple and secure: workspace path managed by server.
# Set true only for advanced self-hosted flows that need per-key subpaths.
# BARDO_ALLOW_CUSTOM_WORKSPACE_PATH=false

# Optional workspace-root override support for remote MCP clients.
# When enabled, client header `x-bardo-workspace-root` can override key claims.
# BARDO_ALLOW_WORKSPACE_ROOT_OVERRIDE=true
# BARDO_WORKSPACE_ROOT_ALLOWLIST=/home/your-user/projects

# Optional Upstash Redis for distributed verification limits
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# BARDO_UPSTASH_TIMEOUT_MS=1200
# BARDO_MCP_USAGE_READ_TOTALS=false
# BARDO_MCP_USAGE_READ_KEY_METADATA=false

# Optional verification budgets (defaults are used if omitted)
# BARDO_DAILY_USER_VERIFICATIONS_FREE=500
# BARDO_DAILY_USER_VERIFICATIONS_SOLO=7500
# BARDO_DAILY_USER_VERIFICATIONS_SOLO_PLUS=13000
# BARDO_DAILY_KEY_VERIFICATIONS_FREE=500
# BARDO_DAILY_KEY_VERIFICATIONS_SOLO=2000
# BARDO_DAILY_KEY_VERIFICATIONS_SOLO_PLUS=3000
# BARDO_VERIFY_BLOCK_CACHE_MS=30000
# BARDO_MCP_PERIOD_LIMIT_FREE=100
# BARDO_MCP_PERIOD_LIMIT_SOLO=25000
# BARDO_MCP_PERIOD_LIMIT_SOLO_PLUS=50000
# BARDO_VERIFICATION_LIMIT_ALLOW_MEMORY_FALLBACK=true

# E2E / Playwright
PLAYWRIGHT_BASE_URL=http://localhost:3001
# PLAYWRIGHT_LOOPBACK_HOST=127.0.0.1
E2E_CLERK_USER_IDENTIFIER=
E2E_CLERK_USER_PASSWORD=

################################################################################
# staging
################################################################################

# Clerk auth (staging instance)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
# CLERK_SECRET_KEY=sk_test_REPLACE_ME
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
#
# Clerk billing plans
# CLERK_BILLING_PLAN_SOLO=cplan_REPLACE_ME
# CLERK_BILLING_PLAN_SOLO_PLUS=cplan_REPLACE_ME
#
# Website + MCP URLs
# NEXT_PUBLIC_APP_URL=https://staging.example.com
# BARDO_MCP_BASE_URL=https://bardo-mcp-staging.up.railway.app
#
# Shared introspection secret (must match mcp/.env)
# BARDO_AUTH_INTROSPECTION_TOKEN=replace_with_shared_server_secret
#
# Optional
# BARDO_INTROSPECTION_PLAN_CACHE_TTL_MS=300000
# BARDO_INTROSPECTION_VERIFY_CACHE_TTL_MS=120000
# BARDO_INTROSPECTION_INVALID_CACHE_TTL_MS=20000
# BARDO_INTROSPECTION_TELEMETRY_LOG=false
# BARDO_INTROSPECTION_TELEMETRY_LOG_EVERY=100
# BARDO_ALLOW_CUSTOM_WORKSPACE_PATH=false
# BARDO_ALLOW_WORKSPACE_ROOT_OVERRIDE=true
# BARDO_WORKSPACE_ROOT_ALLOWLIST=/home/your-user/projects
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# BARDO_UPSTASH_TIMEOUT_MS=1200
# BARDO_MCP_USAGE_READ_TOTALS=false
# BARDO_MCP_USAGE_READ_KEY_METADATA=false
# BARDO_MCP_PERIOD_LIMIT_FREE=100
# BARDO_MCP_PERIOD_LIMIT_SOLO=25000
# BARDO_MCP_PERIOD_LIMIT_SOLO_PLUS=50000
# BARDO_VERIFY_BLOCK_CACHE_MS=30000
# BARDO_VERIFICATION_LIMIT_ALLOW_MEMORY_FALLBACK=false

