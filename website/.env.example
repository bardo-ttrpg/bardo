# ── Clerk Auth ────────────────────────────────────────────────────────────────
# Found in Clerk Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# Clerk sign-in / sign-up redirect URLs (match Clerk Dashboard → Paths)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── Clerk Billing ─────────────────────────────────────────────────────────────
# Plan IDs from Clerk Dashboard → Billing → Plans
# These are used to map live Clerk subscriptions to app plans.
CLERK_BILLING_PLAN_SOLO=cplan_REPLACE_ME
CLERK_BILLING_PLAN_SOLO_PLUS=cplan_REPLACE_ME

# ── App URL ───────────────────────────────────────────────────────────────────
# Full public URL of this Next.js app (used for auth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ── MCP Integration ───────────────────────────────────────────────────────────
# Shared secret between the MCP server and this app for key introspection.
# Must match BARDO_AUTH_INTROSPECTION_TOKEN in the MCP server's .env.
BARDO_AUTH_INTROSPECTION_TOKEN=your-secret-token-here

# ── E2E / Playwright ──────────────────────────────────────────────────────────
PLAYWRIGHT_BASE_URL=http://localhost:3001
# Optional override for local host binding used in Playwright webServer URL.
# PLAYWRIGHT_LOOPBACK_HOST=::1
E2E_CLERK_USER_IDENTIFIER=
E2E_CLERK_USER_PASSWORD=
