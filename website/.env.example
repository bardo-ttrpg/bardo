# Website environment template
# Default local development targets the hosted remote MCP.
# Override BARDO_MCP_BASE_URL to http://127.0.0.1:3000 only when testing a local MCP server.

NEXT_PUBLIC_APP_URL="http://localhost:3001"
BARDO_MCP_BASE_URL="https://mcp.bardo.gg"

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_REPLACE_ME"
CLERK_SECRET_KEY="sk_test_REPLACE_ME"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

CLERK_BILLING_PLAN_SOLO="cplan_REPLACE_ME"

BARDO_AUTH_INTROSPECTION_TOKEN="replace_with_shared_server_secret"
BARDO_BRIDGE_LOGIN_SECRET="replace_with_bridge_session_secret"
BARDO_WEBSITE_BACKEND_SQLITE_PATH="./.data/website-backend.json"

# Hardened local development toggles
BARDO_CLI_DEVICE_SESSION_ALLOW_MEMORY_FALLBACK="false"
BARDO_CLI_LOGIN_REPLAY_ALLOW_MEMORY_FALLBACK="false"
BARDO_VERIFICATION_LIMIT_ALLOW_MEMORY_FALLBACK="false"
# BARDO_INTROSPECTION_PLAN_CACHE_TTL_MS="300000"
# BARDO_INTROSPECTION_VERIFY_CACHE_TTL_MS="120000"
# BARDO_INTROSPECTION_INVALID_CACHE_TTL_MS="20000"
# BARDO_INTROSPECTION_TELEMETRY_LOG="false"
# BARDO_INTROSPECTION_TELEMETRY_LOG_EVERY="100"

# Optional release verification
# BARDO_RC_SHA="<git sha>"

# E2E / Playwright
PLAYWRIGHT_BASE_URL="http://localhost:3001"
E2E_CLERK_EMAIL="your_email+clerk_test@example.com"
E2E_CLERK_PASSWORD="YourEmailClerkTest123!$"
E2E_CLERK_TEST_PHONE_NUMBER="+15555550100"
E2E_CLERK_TEST_VERIFICATION_CODE="424242"

# Staging / production notes:
# - NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY must stay pk_test_* in staging and pk_live_* in production.
# - CLERK_SECRET_KEY must stay sk_test_* in staging and sk_live_* in production.
# - NEXT_PUBLIC_APP_URL and BARDO_MCP_BASE_URL must be https URLs outside local development.
# - Keep BARDO_AUTH_INTROSPECTION_TOKEN and BARDO_BRIDGE_LOGIN_SECRET set in every deployed environment.
