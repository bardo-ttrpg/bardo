{
	"extends": ["//"],
	"tasks": {
		"dev": {
			"cache": false,
			"persistent": true,
			"interruptible": true
		},
		"build": {
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["$TURBO_EXTENDS$", ".next/**", "!.next/cache/**"],
			"env": ["NEXT_PUBLIC_*", "CLERK_*", "BARDO_*"]
		},
		"build:analyze": {
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": [
				"$TURBO_EXTENDS$",
				".next/BUILD_ID",
				".next/build-manifest.json",
				".next/routes-manifest.json",
				".next/app-build-manifest.json",
				".next/static/chunks/**",
				".next/static/media/**",
				".next/diagnostics/**",
				".next/analyze/**"
			],
			"env": [
				"ANALYZE",
				"NEXT_BUILD_ANALYZE_ARGS",
				"NEXT_PUBLIC_*",
				"CLERK_*",
				"BARDO_*"
			]
		},
		"validate:deploy-env": {
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": []
		},
		"validate:development-env": {
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": []
		},
		"validate:staging-env": {
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": []
		},
		"check:release-health": {
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": []
		},
		"check:react-doctor": {
			"outputs": []
		},
		"bundle:audit": {
			"dependsOn": ["build:analyze"],
			"outputs": []
		},
		"typecheck:unused-report": {
			"outputs": []
		}
	}
}
