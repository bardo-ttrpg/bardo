{
	"name": "website",
	"packageManager": "bun@1.3.10",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "next dev --turbopack -p ${PORT:-3001}",
		"validate:development-env": "\"${npm_execpath:-bun}\" run ./scripts/validate-development-env.ts",
		"build": "\"${npm_execpath:-bun}\" run validate:deploy-env && \"${npm_execpath:-bun}\" run check:release-health && next build --turbopack",
		"validate:deploy-env": "\"${npm_execpath:-bun}\" run ./scripts/validate-deploy-env.ts",
		"validate:staging-env": "\"${npm_execpath:-bun}\" run ./scripts/validate-staging-env.ts",
		"check:release-health": "\"${npm_execpath:-bun}\" run ./scripts/check-release-health.ts",
		"check:react-doctor": "\"${npm_execpath:-bun}\" run ./scripts/check-react-doctor.ts",
		"build:analyze": "NEXT_BUILD_ANALYZE_ARGS='build --turbopack --experimental-analyze' ANALYZE=true \"${npm_execpath:-bun}\" run ./scripts/run-build-analyze.ts",
		"bundle:audit": "\"${npm_execpath:-bun}\" run build:analyze && \"${npm_execpath:-bun}\" run ./scripts/bundle-audit.ts",
		"start": "next start -p ${PORT:-3001}",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"typecheck:unused-report": "tsc --noEmit -p tsconfig.unused.json",
		"check": "\"${npm_execpath:-bun}\" run lint && \"${npm_execpath:-bun}\" run typecheck",
		"test": "\"${npm_execpath:-bun}\" test",
		"test:connect-gates": "\"${npm_execpath:-bun}\" test app/api/connect/bridge-session/route-contract.test.ts app/api/connect/bridge-session/start/route.test.ts app/api/connect/bridge-session/poll/route.test.ts app/api/connect/bridge-session/approve/route.test.ts app/api/connect/bridge-session/refresh/route.test.ts app/api/connect/runtime-status/route.test.ts app/api/auth/introspect-key/route.test.ts",
		"ci": "biome ci ."
	},
	"dependencies": {
		"@mdx-js/loader": "^3.1.1",
		"@mdx-js/react": "^3.1.1",
		"@next/mdx": "^16.1.6",
		"@radix-ui/react-separator": "^1.1.7",
		"@radix-ui/react-slot": "^1.2.3",
		"@bardo/mcp": "workspace:*",
		"@clerk/nextjs": "7.0.4",
		"@tailwindcss/postcss": "^4.2.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"geist": "^1.7.0",
		"lucide-react": "^0.542.0",
		"next": "16.1.6",
		"postcss": "^8.5.8",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"remark-gfm": "^4.0.1",
		"tailwindcss": "^4.2.1"
	},
	"devDependencies": {
		"@types/node": "^25.4.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"tailwind-merge": "^3.3.1",
		"typescript": "5.9.3"
	}
}
