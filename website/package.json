{
	"name": "website",
	"packageManager": "bun@1.3.10",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "next dev -p ${PORT:-3001}",
		"dev:e2e": "next dev --hostname ${PLAYWRIGHT_LOOPBACK_HOST:-localhost} -p ${PORT:-3001}",
		"build": "bun run validate:deploy-env && bun run check:release-health && next build",
		"validate:deploy-env": "bun ./scripts/validate-deploy-env.ts",
		"validate:staging-env": "bun ./scripts/validate-staging-env.ts",
		"validate:e2e-auth-env": "bun ./scripts/validate-e2e-auth-env.ts",
		"check:release-health": "bun ./scripts/check-release-health.ts",
		"check:react-doctor": "bun ./scripts/check-react-doctor.ts",
		"build:analyze": "ANALYZE=true next build --webpack",
		"bundle:audit": "bun run build:analyze && bun ./scripts/bundle-audit.ts",
		"start": "next start -p ${PORT:-3001}",
		"lint": "biome check .",
		"typecheck": "tsc --noEmit",
		"check": "bun run lint && bun run typecheck",
		"test": "bun test",
		"test:connect-gates": "bun test app/api/keys/route.test.ts app/api/keys/[id]/route.test.ts app/api/keys/revoke/route.test.ts app/api/connect/cli-session/start/route.test.ts app/api/connect/cli-session/poll/route.test.ts app/api/connect/cli-session/approve/route.test.ts app/api/connect/cli-token/route.test.ts app/api/connect/cli-exchange/route.test.ts app/api/connect/runtime-status/route.test.ts app/api/connect/snippets/route.test.ts",
		"test:e2e": "playwright test --project=chromium",
		"test:e2e:headed": "playwright test --project=chromium --headed",
		"test:e2e:auth": "bun run validate:e2e-auth-env && playwright test --project=chromium-auth",
		"test:e2e:auth:headed": "bun run validate:e2e-auth-env && playwright test --project=chromium-auth --headed"
	},
	"dependencies": {
		"@bardo/mcp": "workspace:*",
		"@clerk/nextjs": "6.38.1",
		"@sentry/nextjs": "10.40.0",
		"@tailwindcss/postcss": "^4.2.0",
		"@vercel/analytics": "^1.6.1",
		"@vercel/speed-insights": "^1.3.1",
		"clsx": "^2.1.1",
		"dotted-map": "^2.2.3",
		"framer-motion": "^12.34.3",
		"geist": "^1.7.0",
		"lucide-react": "^0.575.0",
		"next": "16.1.6",
		"next-themes": "^0.4.6",
		"postcss": "^8.5.6",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.0",
		"tw-animate-css": "^1.4.0"
	},
	"devDependencies": {
		"@clerk/testing": "^2.0.1",
		"@next/bundle-analyzer": "^16.1.6",
		"@playwright/test": "^1.58.2",
		"@sentry/cli": "3.2.3",
		"@types/node": "^25.3.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"shadcn": "^3.8.5",
		"typescript": "5.9.3"
	}
}
