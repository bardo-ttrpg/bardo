{
	"name": "website",
	"packageManager": "bun@1.3.11",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "bun run ./scripts/run-dev.ts --turbopack",
		"validate:development-env": "bun run ./scripts/validate-development-env.ts",
		"build": "bun run validate:deploy-env && bun run check:release-health && next build --turbopack",
		"validate:deploy-env": "bun run ./scripts/validate-deploy-env.ts",
		"validate:staging-env": "bun run ./scripts/validate-staging-env.ts",
		"check:release-health": "bun run ./scripts/check-release-health.ts",
		"check:react-doctor": "bun run ./scripts/check-react-doctor.ts",
		"check:vercel-doctor": "bun run ./scripts/check-vercel-doctor.ts",
		"audit:lighthouse:home": "bun run ./scripts/run-lighthouse-home.ts",
		"build:analyze": "NEXT_BUILD_ANALYZE_ARGS='build --turbopack --experimental-analyze' ANALYZE=true bun run ./scripts/run-build-analyze.ts",
		"bundle:audit": "bun run ./scripts/bundle-audit.ts",
		"start": "next start -p ${PORT:-3001}",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"typecheck:unused-report": "tsc --noEmit -p tsconfig.unused.json",
		"check": "bun run lint && bun run typecheck",
		"test": "bun test",
		"test:connect-gates": "bun test app/api/connect/bridge-session/route-contract.test.ts app/api/connect/bridge-session/start/route.test.ts app/api/connect/bridge-session/poll/route.test.ts app/api/connect/bridge-session/approve/route.test.ts app/api/connect/bridge-session/refresh/route.test.ts app/api/connect/runtime-status/route.test.ts app/api/auth/introspect-key/route.test.ts",
		"ci": "biome ci ."
	},
	"dependencies": {
		"@clerk/nextjs": "7.0.7",
		"@clerk/ui": "1.2.3",
		"@mdx-js/loader": "^3.1.1",
		"@mdx-js/react": "^3.1.1",
		"@next/mdx": "16.2.3",
		"@number-flow/react": "^0.6.0",
		"@tailwindcss/postcss": "^4.2.1",
		"@vercel/analytics": "^1.6.1",
		"@vercel/speed-insights": "^2.0.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^1.7.0",
		"next": "16.2.3",
		"next-themes": "^0.4.6",
		"postcss": "^8.5.8",
		"radix-ui": "^1.4.3",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"remark-gfm": "^4.0.1",
		"tailwindcss": "^4.2.1",
		"tw-animate-css": "^1.4.0"
	},
	"devDependencies": {
		"@types/bun": "^1.3.10",
		"@types/node": "^25.4.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"shadcn": "^4.1.2",
		"tailwind-merge": "^3.5.0",
		"typescript": "5.9.3"
	}
}
