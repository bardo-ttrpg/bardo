{
	"$schema": "https://turbo.build/schema.json",
	"ui": "tui",
	"tasks": {
		"dev": {
			"cache": false,
			"persistent": true
		},
		"build": {
			"dependsOn": ["^build"],
			"outputs": []
		},
		"website#build": {
			"outputs": [".next/**"]
		},
		"mcp#build": {
			"outputs": []
		},
		"lint": {
			"dependsOn": ["^lint"],
			"outputs": []
		},
		"typecheck": {
			"dependsOn": ["^typecheck"],
			"outputs": []
		},
		"check": {
			"dependsOn": ["lint", "typecheck"],
			"outputs": []
		}
	}
}
