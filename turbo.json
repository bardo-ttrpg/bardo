{
	"$schema": "https://turborepo.dev/schema.v2.json",
	"ui": "tui",
	"globalDependencies": [
		"package.json",
		"bun.lock",
		"turbo.json",
		"tsconfig.base.json",
		"biome.json",
		".env*",
		"website/.env*",
		"mcp/.env*"
	],
	"tasks": {
		"dev": {
			"cache": false,
			"persistent": true
		},
		"build": {
			"dependsOn": ["^build"],
			"outputs": []
		},
		"website#build": {
			"outputs": [".next/**", "!.next/cache/**"],
			"env": ["NEXT_PUBLIC_*", "CLERK_*", "BARDO_*", "SENTRY_*", "UPSTASH_*"]
		},
		"mcp#build": {
			"outputs": []
		},
		"lint": {
			"dependsOn": ["^lint"],
			"outputs": []
		},
		"typecheck": {
			"dependsOn": ["^typecheck"],
			"outputs": []
		},
		"test": {
			"dependsOn": ["^test"],
			"outputs": []
		},
		"test:ga-gates": {
			"dependsOn": ["^test:ga-gates"],
			"outputs": []
		},
		"test:perf-gates": {
			"dependsOn": ["^test:perf-gates"],
			"outputs": []
		},
		"check": {
			"dependsOn": ["lint", "typecheck"],
			"outputs": []
		}
	}
}
