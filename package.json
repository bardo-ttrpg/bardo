{
	"name": "bardo-monorepo",
	"private": true,
	"packageManager": "bun@1.3.11",
	"workspaces": [
		"website",
		"packages/*"
	],
	"overrides": {
		"path-to-regexp": "8.4.1",
		"@clerk/shared": "4.3.2",
		"@clerk/localizations": "4.2.3",
		"hono": "4.12.12",
		"@hono/node-server": "1.19.13",
		"basic-ftp": "5.2.1"
	},
	"scripts": {
		"dev": "bun run ./scripts/run-turbo.ts dev --filter=website",
		"dev:all": "bun run ./scripts/run-turbo.ts dev",
		"build": "bun run ./scripts/run-turbo.ts build",
		"lint": "bun run ./scripts/run-turbo.ts lint",
		"format": "bun run ./scripts/run-turbo.ts format",
		"typecheck": "bun run ./scripts/run-turbo.ts typecheck",
		"typecheck:unused-report": "bun run ./scripts/run-turbo.ts typecheck:unused-report --filter=website",
		"test": "bun run ./scripts/run-turbo.ts test",
		"test:connect-gates": "bun run ./scripts/run-turbo.ts test:connect-gates --filter=website && bun run ./scripts/run-turbo.ts test:runtime-smoke --filter=@bardo/mcp",
		"test:runtime-smoke": "bun run ./scripts/run-turbo.ts test:runtime-smoke --filter=@bardo/mcp",
		"inspector:bridge": "bash scripts/mcp-inspector-bridge.sh",
		"test:ga-gates": "bun run ./scripts/run-turbo.ts test:ga-gates --filter=@bardo/engine",
		"test:soak-gates": "bun run ./scripts/run-turbo.ts test:soak-gates --filter=@bardo/engine",
		"test:mechanics-edge-gates": "bun run ./scripts/run-turbo.ts test:mechanics-edge-gates --filter=@bardo/engine",
		"test:perf-gates": "bun run ./scripts/run-turbo.ts test:perf-gates --filter=@bardo/engine",
		"test:release-gates": "bun run test:ga-gates && bun run test:connect-gates",
		"ga:readiness": "bun run ./scripts/run-turbo.ts ga:readiness --filter=@bardo/engine",
		"validate:deploy-env": "bun run ./scripts/run-turbo.ts validate:deploy-env --filter=website",
		"validate:development-env": "bun run ./scripts/run-turbo.ts validate:development-env --filter=website",
		"check:release-health": "bun run ./scripts/run-turbo.ts check:release-health --filter=website",
		"check:react-doctor": "bun run --cwd website check:react-doctor",
		"check:vercel-doctor": "bun run --cwd website check:vercel-doctor",
		"check:production-health": "bun run ./scripts/check-production-health.ts",
		"bundle:audit": "bun run --cwd website bundle:audit",
		"require:clean-worktree": "bun run ./scripts/require-clean-worktree.ts",
		"dev:exit": "bun run require:clean-worktree && bun run check && bun run build && bun run test && bun run test:connect-gates && bun run ga:readiness && bun run check:release-health && bun run check:react-doctor && bun run bundle:audit",
		"dev:exit:clean-room": "bun run ./scripts/dev-exit-clean-room.ts",
		"staging:readiness": "bun run check && bun run build && bun run test && bun run test:release-gates && bun run ga:readiness",
		"staging:validate-env": "bun run ./scripts/run-turbo.ts validate:staging-env --filter=website",
		"staging:smoke": "bun run ./scripts/staging-smoke.ts",
		"stress:test-01": "bun run ./scripts/stress-bardo-test-01.ts",
		"release:candidate": "bun run build && bun run test:release-gates && bun run bundle:audit && bun run stress:test-01",
		"validate:toolchain": "bun run ./scripts/validate-toolchain-policy.ts",
		"check": "bun run validate:toolchain && bun run ./scripts/run-turbo.ts check",
		"knip": "knip",
		"knip:fix": "knip --fix --allow-remove-files --format",
		"check:staged": "biome check --write --staged --files-ignore-unknown=true --no-errors-on-unmatched",
		"clean:artifacts": "bash scripts/clean-artifacts.sh",
		"biome:lint": "biome lint .",
		"biome:format": "biome format --write .",
		"biome:check": "biome check .",
		"biome:ci": "biome ci .",
		"biome:write": "biome check --write .",
		"dev:website": "bun run ./scripts/run-turbo.ts dev --filter=website",
		"dev:bridge": "bun run ./scripts/run-turbo.ts dev --filter=@bardo/mcp",
		"prepare": "bun run ./scripts/prepare-husky.ts"
	},
	"devDependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@types/bun": "^1.3.10",
		"@types/node": "^25.4.0",
		"@biomejs/biome": "2.4.6",
		"husky": "^9.1.7",
		"knip": "^6.6.0",
		"turbo": "^2.9.6",
		"typescript": "5.9.3"
	}
}
