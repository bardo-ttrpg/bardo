{
	"name": "bardo-monorepo",
	"private": true,
	"packageManager": "bun@1.3.10",
	"workspaces": [
		"website",
		"mcp",
		"packages/*"
	],
	"scripts": {
		"dev": "turbo run dev --filter=website",
		"dev:all": "turbo run dev",
		"build": "turbo run build",
		"lint": "turbo run lint",
		"format": "turbo run format",
		"typecheck": "turbo run typecheck",
		"typecheck:unused-report": "turbo run typecheck:unused-report --filter=website --filter=mcp",
		"test": "turbo run test",
		"test:connect-gates": "turbo run test:connect-gates --filter=website && turbo run test:runtime-smoke --filter=@bardo/mcp",
		"test:runtime-smoke": "turbo run test:runtime-smoke --filter=@bardo/mcp",
		"inspector:bridge": "bash scripts/mcp-inspector-bridge.sh",
		"inspector:remote": "bash scripts/mcp-inspector-remote.sh",
		"test:ga-gates": "turbo run test:ga-gates --filter=mcp",
		"test:soak-gates": "turbo run test:soak-gates --filter=mcp",
		"test:mechanics-edge-gates": "turbo run test:mechanics-edge-gates --filter=mcp",
		"test:perf-gates": "turbo run test:perf-gates --filter=mcp",
		"test:release-gates": "\"${npm_execpath:-bun}\" run test:ga-gates && \"${npm_execpath:-bun}\" run test:connect-gates",
		"ga:readiness": "turbo run ga:readiness --filter=mcp",
		"validate:deploy-env": "turbo run validate:deploy-env --filter=website",
		"validate:development-env": "turbo run validate:development-env --filter=website --filter=mcp",
		"check:release-health": "turbo run check:release-health --filter=website",
		"check:react-doctor": "turbo run check:react-doctor --filter=website",
		"bundle:audit": "turbo run bundle:audit --filter=website",
		"require:clean-worktree": "\"${npm_execpath:-bun}\" run ./scripts/require-clean-worktree.ts",
		"dev:exit": "\"${npm_execpath:-bun}\" run require:clean-worktree && \"${npm_execpath:-bun}\" run check && \"${npm_execpath:-bun}\" run build && \"${npm_execpath:-bun}\" run test && \"${npm_execpath:-bun}\" run test:connect-gates && \"${npm_execpath:-bun}\" run ga:readiness && \"${npm_execpath:-bun}\" run check:release-health && \"${npm_execpath:-bun}\" run check:react-doctor && \"${npm_execpath:-bun}\" run bundle:audit",
		"dev:exit:clean-room": "\"${npm_execpath:-bun}\" run ./scripts/dev-exit-clean-room.ts",
		"staging:readiness": "\"${npm_execpath:-bun}\" run check && \"${npm_execpath:-bun}\" run build && \"${npm_execpath:-bun}\" run test && \"${npm_execpath:-bun}\" run test:release-gates && \"${npm_execpath:-bun}\" run ga:readiness",
		"staging:validate-env": "turbo run validate:staging-env --filter=website --filter=mcp",
		"staging:smoke": "\"${npm_execpath:-bun}\" run ./scripts/staging-smoke.ts",
		"validate:toolchain": "\"${npm_execpath:-bun}\" run ./scripts/validate-toolchain-policy.ts",
		"check": "\"${npm_execpath:-bun}\" run validate:toolchain && turbo run check",
		"knip": "knip",
		"knip:fix": "knip --fix --allow-remove-files --format",
		"check:staged": "biome check --write --staged --files-ignore-unknown=true --no-errors-on-unmatched",
		"clean:artifacts": "bash scripts/clean-artifacts.sh",
		"biome:lint": "biome lint .",
		"biome:format": "biome format --write .",
		"biome:check": "biome check .",
		"biome:ci": "biome ci .",
		"biome:write": "biome check --write .",
		"dev:website": "turbo run dev --filter=website",
		"dev:mcp": "turbo run dev --filter=mcp",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"husky": "^9.1.7",
		"knip": "^6.1.1",
		"turbo": "^2.9.1",
		"typescript": "5.9.3"
	}
}
