{
	"name": "bardo-monorepo",
	"private": true,
	"packageManager": "bun@1.3.11",
	"workspaces": [
		"website",
		"packages/*"
	],
	"overrides": {
		"path-to-regexp": "8.4.1",
		"@clerk/shared": "4.3.2",
		"@clerk/localizations": "4.2.3",
		"hono": "4.12.12",
		"@hono/node-server": "1.19.13",
		"basic-ftp": "5.2.1"
	},
	"scripts": {
		"dev": "\"${npm_execpath:-bun}\" run ./scripts/run-turbo.ts dev --filter=website",
		"dev:all": "\"${npm_execpath:-bun}\" run ./scripts/run-turbo.ts dev",
		"build": "\"${npm_execpath:-bun}\" run ./scripts/run-turbo.ts build",
		"lint": "\"${npm_execpath:-bun}\" run ./scripts/run-turbo.ts lint",
		"format": "\"${npm_execpath:-bun}\" run ./scripts/run-turbo.ts format",
		"typecheck": "\"${npm_execpath:-bun}\" run ./scripts/run-turbo.ts typecheck",
		"typecheck:unused-report": "\"${npm_execpath:-bun}\" run ./scripts/run-turbo.ts typecheck:unused-report --filter=website",
		"test": "\"${npm_execpath:-bun}\" run ./scripts/run-turbo.ts test",
		"test:connect-gates": "\"${npm_execpath:-bun}\" run ./scripts/run-turbo.ts test:connect-gates --filter=website && \"${npm_execpath:-bun}\" run ./scripts/run-turbo.ts test:runtime-smoke --filter=@bardo/mcp",
		"test:runtime-smoke": "\"${npm_execpath:-bun}\" run ./scripts/run-turbo.ts test:runtime-smoke --filter=@bardo/mcp",
		"inspector:bridge": "bash scripts/mcp-inspector-bridge.sh",
		"test:ga-gates": "\"${npm_execpath:-bun}\" run ./scripts/run-turbo.ts test:ga-gates --filter=@bardo/engine",
		"test:soak-gates": "\"${npm_execpath:-bun}\" run ./scripts/run-turbo.ts test:soak-gates --filter=@bardo/engine",
		"test:mechanics-edge-gates": "\"${npm_execpath:-bun}\" run ./scripts/run-turbo.ts test:mechanics-edge-gates --filter=@bardo/engine",
		"test:perf-gates": "\"${npm_execpath:-bun}\" run ./scripts/run-turbo.ts test:perf-gates --filter=@bardo/engine",
		"test:release-gates": "\"${npm_execpath:-bun}\" run test:ga-gates && \"${npm_execpath:-bun}\" run test:connect-gates",
		"ga:readiness": "\"${npm_execpath:-bun}\" run ./scripts/run-turbo.ts ga:readiness --filter=@bardo/engine",
		"validate:deploy-env": "\"${npm_execpath:-bun}\" run ./scripts/run-turbo.ts validate:deploy-env --filter=website",
		"validate:development-env": "\"${npm_execpath:-bun}\" run ./scripts/run-turbo.ts validate:development-env --filter=website",
		"check:release-health": "\"${npm_execpath:-bun}\" run ./scripts/run-turbo.ts check:release-health --filter=website",
		"check:react-doctor": "\"${npm_execpath:-bun}\" run --cwd website check:react-doctor",
		"check:vercel-doctor": "\"${npm_execpath:-bun}\" run --cwd website check:vercel-doctor",
		"check:production-health": "\"${npm_execpath:-bun}\" run ./scripts/check-production-health.ts",
		"bundle:audit": "\"${npm_execpath:-bun}\" run --cwd website bundle:audit",
		"require:clean-worktree": "\"${npm_execpath:-bun}\" run ./scripts/require-clean-worktree.ts",
		"dev:exit": "\"${npm_execpath:-bun}\" run require:clean-worktree && \"${npm_execpath:-bun}\" run check && \"${npm_execpath:-bun}\" run build && \"${npm_execpath:-bun}\" run test && \"${npm_execpath:-bun}\" run test:connect-gates && \"${npm_execpath:-bun}\" run ga:readiness && \"${npm_execpath:-bun}\" run check:release-health && \"${npm_execpath:-bun}\" run check:react-doctor && \"${npm_execpath:-bun}\" run bundle:audit",
		"dev:exit:clean-room": "\"${npm_execpath:-bun}\" run ./scripts/dev-exit-clean-room.ts",
		"staging:readiness": "\"${npm_execpath:-bun}\" run check && \"${npm_execpath:-bun}\" run build && \"${npm_execpath:-bun}\" run test && \"${npm_execpath:-bun}\" run test:release-gates && \"${npm_execpath:-bun}\" run ga:readiness",
		"staging:validate-env": "\"${npm_execpath:-bun}\" run ./scripts/run-turbo.ts validate:staging-env --filter=website",
		"staging:smoke": "\"${npm_execpath:-bun}\" run ./scripts/staging-smoke.ts",
		"stress:test-01": "\"${npm_execpath:-bun}\" run ./scripts/stress-bardo-test-01.ts",
		"release:candidate": "\"${npm_execpath:-bun}\" run build && \"${npm_execpath:-bun}\" run test:release-gates && \"${npm_execpath:-bun}\" run bundle:audit && \"${npm_execpath:-bun}\" run stress:test-01",
		"validate:toolchain": "\"${npm_execpath:-bun}\" run ./scripts/validate-toolchain-policy.ts",
		"check": "\"${npm_execpath:-bun}\" run validate:toolchain && \"${npm_execpath:-bun}\" run ./scripts/run-turbo.ts check",
		"knip": "knip",
		"knip:fix": "knip --fix --allow-remove-files --format",
		"check:staged": "biome check --write --staged --files-ignore-unknown=true --no-errors-on-unmatched",
		"clean:artifacts": "bash scripts/clean-artifacts.sh",
		"biome:lint": "biome lint .",
		"biome:format": "biome format --write .",
		"biome:check": "biome check .",
		"biome:ci": "biome ci .",
		"biome:write": "biome check --write .",
		"dev:website": "\"${npm_execpath:-bun}\" run ./scripts/run-turbo.ts dev --filter=website",
		"dev:bridge": "\"${npm_execpath:-bun}\" run ./scripts/run-turbo.ts dev --filter=@bardo/mcp",
		"prepare": "husky"
	},
	"devDependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@biomejs/biome": "2.4.6",
		"husky": "^9.1.7",
		"knip": "^6.3.1",
		"turbo": "^2.9.5",
		"typescript": "5.9.3"
	}
}
