{
	"name": "bardo-monorepo",
	"private": true,
	"packageManager": "bun@1.3.10",
	"workspaces": [
		"website",
		"mcp",
		"packages/*"
	],
	"scripts": {
		"dev": "turbo run dev --parallel",
		"build": "turbo run build",
		"lint": "turbo run lint",
		"typecheck": "turbo run typecheck",
		"typecheck:unused-report": "bun run typecheck:unused-report:website && bun run typecheck:unused-report:mcp",
		"typecheck:unused-report:website": "bun run --cwd website tsc --noEmit -p tsconfig.unused.json",
		"typecheck:unused-report:mcp": "bun run --cwd mcp tsc --noEmit -p tsconfig.unused.json",
		"test": "turbo run test",
		"test:e2e": "cd website && bun run test:e2e",
		"test:e2e:headed": "cd website && bun run test:e2e:headed",
		"test:ga-gates": "turbo run test:ga-gates --filter=mcp",
		"test:perf-gates": "turbo run test:perf-gates --filter=mcp",
		"test:release-gates": "bun run test:ga-gates && bun run test:e2e",
		"check": "turbo run check",
		"check:staged": "lint-staged",
		"clean:artifacts": "bash scripts/clean-artifacts.sh",
		"biome:check": "biome check .",
		"biome:write": "biome check --write .",
		"dev:website": "turbo run dev --filter=website",
		"dev:mcp": "turbo run dev --filter=mcp",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.4",
		"husky": "^9.1.7",
		"lint-staged": "^16.3.2",
		"turbo": "^2.8.14",
		"typescript": "5.9.3"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,json,md,yml,yaml}": "biome check --write --files-ignore-unknown=true --no-errors-on-unmatched"
	}
}
