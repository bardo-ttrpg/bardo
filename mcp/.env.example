NODE_ENV=production
PORT=3000

# Authentication and caller mapping.
# JSON object mapping API keys to customer workspace paths.
# Example: {"prod_key":"./customers/prod"}
BARDO_API_KEYS_JSON=
BARDO_AUTH_MODE=required
BARDO_ALLOW_QUERY_API_KEY=false
BARDO_AUTH_PROVIDER=hybrid
BARDO_AUTH_INTROSPECTION_URL=
BARDO_AUTH_INTROSPECTION_TOKEN=
BARDO_AUTH_CACHE_TTL_MS=30000

# Optional local development override; keep unset in production.
BARDO_DEFAULT_API_KEY=
BARDO_DEFAULT_API_KEY_LOCALHOST_ONLY=true

# Canonical runtime behavior.
BARDO_STRICT_CANONICAL_MODE=true
BARDO_GUIDED_SETUP_ENABLED=false
BARDO_DEFAULT_RULESET=d20_v1

# Tool policy defaults to gameplay in production when unset.
BARDO_TOOLS_PROFILE=gameplay
BARDO_TOOLS_ALLOW=
BARDO_TOOLS_DENY=
BARDO_TOOLS_BY_PROVIDER_JSON=

# Loop detection.
BARDO_LOOP_DETECTION_ENABLED=true
BARDO_LOOP_HISTORY_SIZE=50
BARDO_LOOP_WARNING_THRESHOLD=3
BARDO_LOOP_CRITICAL_THRESHOLD=5
BARDO_LOOP_GLOBAL_CIRCUIT_BREAKER_THRESHOLD=8

# Request and session controls.
BARDO_MAX_REQUEST_BYTES=1048576
BARDO_SESSION_TTL_MS=3600000

# Rate limiting. Fail closed in production.
BARDO_RATE_LIMIT_WINDOW_MS=60000
BARDO_RATE_LIMIT_MAX_REQUESTS=120
BARDO_RATE_LIMIT_FAIL_CLOSED=true

# Telemetry and metrics.
BARDO_TELEMETRY_ENABLED=true
BARDO_METRICS_ROUTE_ENABLED=true
BARDO_METRICS_REQUIRE_AUTH=true

# Optional Upstash backing for distributed rate limiting.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
