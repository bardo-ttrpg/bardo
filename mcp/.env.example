# MCP environment template
# Local development normally receives Clerk-backed bridge/session credentials from the website.

NODE_ENV=development
PORT=3000

BARDO_AUTH_PROVIDER=hosted
BARDO_AUTH_MODE=required
BARDO_AUTH_INTROSPECTION_URL=http://localhost:3001/api/auth/introspect-key
BARDO_AUTH_INTROSPECTION_TOKEN=replace_with_shared_server_secret
BARDO_ALLOW_QUERY_API_KEY=false

BARDO_STRICT_CANONICAL_MODE=true
BARDO_DEFAULT_RULESET=d20_v1
BARDO_GUIDED_SETUP_ENABLED=true
BARDO_SETUP_CONTRACT_V2_REQUIRED=true
BARDO_MCP_TRANSPORT_MODE=stateless
BARDO_MCP_ENABLE_JSON_RESPONSE=true

BARDO_MAX_REQUEST_BYTES=1048576
BARDO_RATE_LIMIT_WINDOW_MS=60000
BARDO_RATE_LIMIT_MAX_REQUESTS=10000
BARDO_RATE_LIMIT_FAIL_CLOSED=false
BARDO_TELEMETRY_ENABLED=true
BARDO_METRICS_ROUTE_ENABLED=true
BARDO_METRICS_REQUIRE_AUTH=true

# Local-only fallback to keep development moving when durable usage storage is absent.
# Keep this false outside local development.
# BARDO_MCP_USAGE_LIMIT_ALLOW_MEMORY_FALLBACK=true

# Optional hardening / debugging controls
# BARDO_AUTH_CACHE_TTL_MS=120000
# BARDO_AUTH_INVALID_CACHE_TTL_MS=30000
# BARDO_AUTH_INTROSPECTION_TIMEOUT_MS=10000
# BARDO_ALLOW_WORKSPACE_ROOT_OVERRIDE=true
# BARDO_REQUIRE_WORKSPACE_ROOT=false
# BARDO_WORKSPACE_ROOT_ALLOWLIST=/home/your-user/projects,/tmp
# BARDO_WORKSPACE_LAYOUT=nested

# Staging / production notes:
# - Use NODE_ENV=production.
# - Keep BARDO_AUTH_PROVIDER=hosted and BARDO_AUTH_MODE=required.
# - Point BARDO_AUTH_INTROSPECTION_URL at the deployed website.
# - Keep BARDO_ALLOW_QUERY_API_KEY=false and BARDO_MCP_USAGE_LIMIT_ALLOW_MEMORY_FALLBACK=false.
