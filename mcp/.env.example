# MCP environment template
# Use one section at a time. Do not mix local-dev, staging, and production values.

################################################################################
# local-dev
################################################################################

NODE_ENV=development
PORT=3000

# Auth (website introspection)
BARDO_AUTH_PROVIDER=hosted
BARDO_AUTH_MODE=required
BARDO_AUTH_INTROSPECTION_URL=http://127.0.0.1:3001/api/auth/introspect-key
BARDO_AUTH_INTROSPECTION_TOKEN=replace_with_shared_server_secret
BARDO_ALLOW_QUERY_API_KEY=false

# Workspace behavior (local workflows)
# When enabled, clients can pass x-bardo-workspace-root to bind execution root.
# BARDO_ALLOW_WORKSPACE_ROOT_OVERRIDE=true
# BARDO_REQUIRE_WORKSPACE_ROOT=false
# BARDO_WORKSPACE_ROOT_ALLOWLIST=/home/your-user/projects,/tmp

# Runtime defaults
BARDO_STRICT_CANONICAL_MODE=true
BARDO_DEFAULT_RULESET=d20_v1
BARDO_GUIDED_SETUP_ENABLED=false
# Require setup clients to send x-bardo-setup-contract-version: 2.0 for init/player_action.
# Keep false during migration; set true after all clients adopt setupPrompt.
# BARDO_SETUP_CONTRACT_V2_REQUIRED=false
BARDO_MCP_TRANSPORT_MODE=stateful
# Workspace layout:
# - nested (default): writes under <campaignBasePath>/bardo
# - flat: writes directly under <campaignBasePath>
# BARDO_WORKSPACE_LAYOUT=flat

# Optional cost/latency tuning
# BARDO_SESSION_TTL_MS=3600000
# BARDO_AUTH_CACHE_TTL_MS=120000
# BARDO_AUTH_INVALID_CACHE_TTL_MS=30000
# BARDO_AUTH_INTROSPECTION_TIMEOUT_MS=10000

# Optional protections / observability
# BARDO_MAX_REQUEST_BYTES=1048576
# BARDO_RATE_LIMIT_WINDOW_MS=60000
# BARDO_RATE_LIMIT_MAX_REQUESTS=120
# BARDO_RATE_LIMIT_FAIL_CLOSED=true
# BARDO_TELEMETRY_ENABLED=true
# BARDO_METRICS_ROUTE_ENABLED=true
# BARDO_METRICS_REQUIRE_AUTH=true

# Optional Upstash Redis rate-limit backend
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# BARDO_MCP_USAGE_LIMIT_ALLOW_MEMORY_FALLBACK=true
# BARDO_MCP_USAGE_WRITE_TOTALS=false
# BARDO_MCP_USAGE_WRITE_LAST_USED=false
# BARDO_MCP_USAGE_WRITE_MODEL_METADATA=false
# BARDO_MCP_USAGE_BLOCK_CACHE_MS=30000

