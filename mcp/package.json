{
	"name": "mcp",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bun --watch index.ts",
		"start": "bun run index.ts",
		"build": "tsc --noEmit",
		"lint": "biome check .",
		"format": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"check": "bun run lint && bun run typecheck"
	},
	"dependencies": {
		"@upstash/ratelimit": "^2.0.8",
		"@upstash/redis": "^1.36.2",
		"@modelcontextprotocol/sdk": "^1.26.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/bun": "^1.3.9",
		"@types/node": "^25.3.0",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"typescript": "^5 || ^6.0.0-beta"
	}
}
