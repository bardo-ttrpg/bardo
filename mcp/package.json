		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/node": "^20.17.57",
		"typescript": "^5.7.3"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}
