{
	"$schema": "https://railway.com/railway.schema.json",
	"build": {
		"watchPatterns": [
			"/index.ts",
			"/src/**",
			"/package.json",
			"/tsconfig.json",
			"/railway.json"
		],
		"buildCommand": "bun install"
	},
	"deploy": {
		"startCommand": "bun run start",
		"numReplicas": 1,
		"healthcheckPath": "/health",
		"healthcheckTimeout": 120,
		"restartPolicyType": "ON_FAILURE",
		"restartPolicyMaxRetries": 10
	}
}
