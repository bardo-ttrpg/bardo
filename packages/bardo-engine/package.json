{
	"name": "@bardo/engine",
	"version": "0.1.0",
	"private": true,
	"packageManager": "bun@1.3.11",
	"type": "module",
	"exports": {
		"./workspace": "./src/workspace.ts",
		"./rules-bootstrap": "./src/rules-bootstrap.ts",
		"./campaign-bootstrap": "./src/campaign-bootstrap.ts",
		"./runtime-tools": "./src/runtime-tools.ts"
	},
	"scripts": {
		"build": "tsc --noEmit",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"test:ga-gates": "bun test src/runtime-contracts.test.ts src/runtime-evals.test.ts src/runtime-tools.test.ts src/campaign-bootstrap.test.ts src/rules-bootstrap.test.ts src/workspace.test.ts",
		"test:soak-gates": "bun test src/runtime-tools.test.ts",
		"test:mechanics-edge-gates": "bun test src/runtime-tools.test.ts",
		"test:perf-gates": "bun test src/runtime-tools.test.ts",
		"ga:readiness": "bun run check && bun run test && bun run test:ga-gates",
		"check": "bun run lint && bun run typecheck"
	},
	"devDependencies": {
		"@types/bun": "^1.3.10",
		"@types/node": "^25.4.0",
		"typescript": "5.9.3"
	}
}
