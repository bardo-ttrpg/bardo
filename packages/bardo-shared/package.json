{
	"name": "@bardo/shared",
	"version": "0.1.0",
	"private": true,
	"packageManager": "bun@1.3.11",
	"type": "module",
	"exports": {
		"./client-adapters": "./src/client-adapters.ts"
	},
	"scripts": {
		"build": "tsc --noEmit",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"test": "\"${npm_execpath:-bun}\" test",
		"check": "\"${npm_execpath:-bun}\" run lint && \"${npm_execpath:-bun}\" run typecheck"
	},
	"devDependencies": {
		"@types/bun": "^1.3.10",
		"typescript": "5.9.3"
	}
}
