{
	"name": "@bardo/mcp",
	"version": "0.1.1",
	"description": "Local-first MCP server for grounded tabletop campaign play with Bardo.",
	"mcpName": "io.github.armando-andre/bardo",
	"packageManager": "bun@1.3.11",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/armando-andre/bardo-mcp.git"
	},
	"homepage": "https://bardo.gg",
	"bugs": {
		"url": "https://github.com/armando-andre/bardo-mcp/issues"
	},
	"license": "SEE LICENSE IN LICENSE",
	"keywords": [
		"mcp",
		"model-context-protocol",
		"ttrpg",
		"tabletop",
		"campaign",
		"local-first",
		"bardo"
	],
	"engines": {
		"node": ">=18"
	},
	"bin": {
		"bardo": "bin/bardo.js",
		"bardo-mcp": "bin/bardo-mcp.js"
	},
	"files": [
		"README.md",
		"SECURITY.md",
		"CHANGELOG.md",
		"LICENSE",
		"server.json",
		"bin",
		"docs",
		"examples",
		"evals",
		"skills",
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"dev": "bun --watch run src/cli.ts",
		"start": "bun run src/cli.ts",
		"build": "bun run build:release",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"check": "bun run lint && bun run typecheck",
		"test": "bun test",
		"test:runtime-smoke": "bun test src/runtime.smoke.test.ts",
		"build:release": "bun run ./scripts/build-release-binaries.ts",
		"ci": "biome ci ."
	},
	"devDependencies": {
		"@bardo/engine": "workspace:*",
		"@bardo/shared": "workspace:*",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@types/bun": "^1.3.10",
		"@types/node": "^25.4.0",
		"typescript": "5.9.3"
	}
}
