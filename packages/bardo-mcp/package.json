{
	"name": "@bardo/mcp",
	"version": "0.1.0",
	"description": "Bardo MCP local adapter for Bun-based MCP clients.",
	"packageManager": "bun@1.3.10",
	"type": "module",
	"exports": {
		"./client-adapters": "./src/client-adapters.ts"
	},
	"engines": {
		"bun": ">=1.3.10"
	},
	"bin": {
		"bardo": "./bin/bardo.js",
		"bardo-mcp": "./bin/bardo-mcp.js"
	},
	"files": [
		"bin",
		"src",
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"start": "\"${npm_execpath:-bun}\" run src/cli.ts",
		"build": "\"${npm_execpath:-bun}\" run build:release",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"check": "\"${npm_execpath:-bun}\" run lint && \"${npm_execpath:-bun}\" run typecheck",
		"test": "\"${npm_execpath:-bun}\" test",
		"test:runtime-smoke": "\"${npm_execpath:-bun}\" test src/runtime.smoke.test.ts",
		"build:release": "\"${npm_execpath:-bun}\" run ./scripts/build-release-binaries.ts",
		"ci": "biome ci ."
	},
	"devDependencies": {
		"@types/bun": "^1.3.10",
		"@types/node": "^25.4.0",
		"typescript": "5.9.3"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.27.1"
	}
}
