{
	"name": "@bardo/mcp",
	"version": "0.1.0",
	"description": "Bardo MCP local adapter for Bun-based MCP clients.",
	"type": "module",
	"exports": {
		"./client-adapters": "./src/client-adapters.ts"
	},
	"engines": {
		"bun": ">=1.3.10"
	},
	"bin": {
		"bardo": "./bin/bardo.js",
		"bardo-mcp": "./bin/bardo-mcp.js"
	},
	"files": [
		"bin",
		"src",
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"start": "bun run src/cli.ts",
		"test": "bun test",
		"build:release": "bun run ./scripts/build-release-binaries.ts"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.26.0"
	}
}
